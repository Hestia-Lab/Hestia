{
  "name": "@hestia/circuits",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:circuits": "node scripts/build.mjs",
    "ceremony": "node scripts/ceremony.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist build"
  },
  "dependencies": {
    "@hestia/common": "workspace:*",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@types/node": "^22",
    "circomlib": "^2.0.5",
    "rimraf": "^6.0.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
